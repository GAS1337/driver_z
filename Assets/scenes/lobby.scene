      "Components": [
        {
          "__type": "Sandbox.TextRenderer",
          "__guid": "0579c019-ef1f-41be-9312-cd4798b8078a",
          "__enabled": true,
          "Flags": 0,
          "__version": 2,
          "BlendMode": "Normal",
          "FogStrength": 1,
          "HorizontalAlignment": "Center",
          "OnComponentDestroy": null,
          "OnComponentDisabled": null,
          "OnComponentEnabled": null,
          "OnComponentFixedUpdate": null,
          "OnComponentStart": null,
          "OnComponentUpdate": null,
          "RenderOptions": {
            "GameLayer": true,
            "OverlayLayer": false,
            "BloomLayer": false,
            "AfterUILayer": false
          },
          "Scale": 1,
          "TextScope": {
            "Text": "Mouse Look around\nWASD to move\nSHIFT to Sprint\nIf its your first time check out the Tutorial on the left",
            "TextColor": "1.65936,1.68264,1.74884,1",
            "FontName": "Poppins",
            "FontSize": 64,
            "FontWeight": 800,
            "FontItalic": false,
