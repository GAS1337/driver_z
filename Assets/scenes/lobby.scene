    {
      "__guid": "07dd51ae-01ba-456e-887d-e168e3d9970d",
      "__version": 2,
      "Flags": 0,
      "Name": "WASD Text",
      "Position": "-3761,335.999634,364",
      "Rotation": "0,0,1,-4.37113883E-08",
      "Scale": "1,1,1",
      "Tags": "",
      "Enabled": true,
      "NetworkMode": 2,
