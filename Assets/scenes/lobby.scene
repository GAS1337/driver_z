    {
      "__guid": "359b19eb-84f3-4ebe-b6d0-2ee87852fc05",
      "__version": 2,
      "Flags": 0,
      "Name": "Big Explanation Text",
      "Position": "-13913.1738,-12689.6836,963.000061",
      "Rotation": "0,-0,-0.965925813,0.258819073",
      "Scale": "1,1,1",
      "Tags": "",
      "Enabled": true,
      "NetworkMode": 2,
      "NetworkFlags": 0,
      "NetworkOrphaned": 0,
      "NetworkTransmit": true,
      "OwnerTransfer": 1,
      "Components": [
        {
          "__type": "Sandbox.TextRenderer",
          "__guid": "18ddff62-65e7-4ae3-93fb-08f0915c7774",
          "__enabled": true,
          "Flags": 0,
          "__version": 2,
          "BlendMode": "Normal",
          "FogStrength": 1,
          "HorizontalAlignment": "Center",
          "OnComponentDestroy": null,
          "OnComponentDisabled": null,
          "OnComponentEnabled": null,
          "OnComponentFixedUpdate": null,
          "OnComponentStart": null,
          "OnComponentUpdate": null,
          "RenderOptions": {
            "GameLayer": true,
            "OverlayLayer": false,
            "BloomLayer": false,
            "AfterUILayer": false
          },
          "Scale": 1,
          "TextScope": {
            "Text": "Controls\n• Leftclick to Shoot\n• Rightclick to shoot Grenade Launcher\nProtip: Grenade Shells cause Knockback to yourself, but no damage \nand you can use them to rocket jump or unstuck yourself\n• Spacebar for Handbrake \nif youre flying you can hold Spacebar to righten yourself\nYou can also damage enemies by ramming them",
            "TextColor": "5,5,5,1",
            "FontName": "Poppins",
            "FontSize": 64,
            "FontWeight": 800,
            "FontItalic": false,
            "FontVariantNumeric": "Normal",
            "LineHeight": 1,
            "LetterSpacing": 0,
            "WordSpacing": 0,
            "FilterMode": "Bilinear",
            "FontSmooth": "Auto",
            "Outline": {
              "Enabled": false,
              "Size": 4,
              "Color": "0,0,1,1"
            },
            "Shadow": {
              "Enabled": false,
              "Size": 4,
              "Color": "0,0,0,1",
              "Offset": "4,4"
